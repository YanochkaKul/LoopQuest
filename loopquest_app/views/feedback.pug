doctype html
html
  head
    title LoopQuest - Feedback
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    link(rel="stylesheet" href="style.css")
  body
    .feedback-container
      //-results
      .result-banner(class=isCorrect ? 'correct' : 'incorrect')
        if isCorrect
          h1 + Correct!
          p.motivation You're mastering those loops!
        else
          h1 - Incorrect!
          p.penalty Skip your next turn on the physical board.
      
      .details-card
        h3 Question Recap
        p.q-text #{questionText}
        .answer-comparison
          p Your answer: 
            span.user-val #{userAnswer}
          if !isCorrect
            p Correct answer: 
              span.correct-val #{correctAnswer}

      //- Progress Scale
      .progress-section
        h3 Your Progress
        .stats-grid
          .stat-box
            span.label Total: 
            span.value #{total}
          .stat-box
            span.label Correct: 
            span.value #{correct}
        
        .score-bar-container
          .score-bar(style=`width: ${score}%`)
          span.score-label #{score}% Accuracy

      //- button to go back
      .action-area
        a.button.submit-btn(href="/rules") Return to Rules

    //- Hidden field to pass server data to the external JS file
    input#answer-status(type="hidden" value=isCorrect.toString())

    //- Audio elements for game feedback
    audio#correct-sound(src="/correct.mp3")
    audio#wrong-sound(src="/wrong.mp3")

    //- Include the external JavaScript file (placed at the bottom as required by labs)
    script(src="/audio.js")    